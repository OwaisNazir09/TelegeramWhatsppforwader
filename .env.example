# Telegram API credentials (get from https://my.telegram.org/apps)
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# (Optional) Chrome path — usually auto-detected on Render
# CHROME_PATH=/usr/bin/google-chrome-stable

# (Optional) Your Render app URL — enables self-ping to keep server alive
# Set this in Render's Environment Variables after deploy
# RENDER_EXTERNAL_URL=https://your-app-name.onrender.com

# Port — Render sets this automatically, no need to change
# PORT=3000
